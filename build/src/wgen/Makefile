wgen_spin_symbol.cxx.s:
	cd /home/jhj/compiler/build && $(MAKE) -f src/wgen/CMakeFiles/wgen42-mips.dir/build.make src/wgen/CMakeFiles/wgen42-mips.dir/wgen_spin_symbol.cxx.s
.PHONY : wgen_spin_symbol.cxx.s

